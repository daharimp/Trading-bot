# Copy this file to .env and fill in your credentials
# NEVER commit .env to git

# Discord Bot Token
# Get it from: https://discord.com/developers/applications -> Your App -> Bot -> Token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Alpaca API Credentials
# Get from: https://app.alpaca.markets -> API Keys
# Use paper trading keys to start (safe, no real money)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here

# Set to "paper" for paper trading (safe) or "live" for real money
ALPACA_MODE=paper

# Discord channel name the bot should listen in (e.g. "trade-ideas")
DISCORD_CHANNEL_NAME=trade-ideas

# OpenAI API Key (used for GPT-4o analysis)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
