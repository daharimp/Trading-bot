# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Alpaca API credentials (paper or live)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
ALPACA_MODE=paper   # paper | live

# Discord channel name to listen in (leave blank to listen in all channels)
DISCORD_CHANNEL_NAME=trading

# Anthropic API key (only needed if TECHNICAL_LLM_MODEL is a Claude model, e.g. claude-sonnet-4-6)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter API key (used for both technical and fundamental LLM analysis)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Technical analysis model — any OpenRouter model (contains "/") routes via OpenRouter,
# otherwise routes via Anthropic directly. Default is Mistral Small 3.2 on OpenRouter.
TECHNICAL_LLM_MODEL=mistralai/mistral-small-3.2-24b-instruct

# Alpha Vantage API key (free at alphavantage.co — fundamental data for stocks)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Fundamental analysis model (via OpenRouter)
FUNDAMENTAL_LLM_MODEL=tencent/hunyuan-3-preview

# Time (ET, 24h) to run overnight watchlist analysis automatically
ANALYSIS_SCHEDULE_TIME=23:00

# Default share quantity for auto-placed orders (!watch TICKER auto)
DEFAULT_QTY=1

# Kraken API credentials (optional — required only for crypto order placement)
# Data fetching (bars, quotes) works without these; only !play / auto-play orders need them.
# Get keys at: https://www.kraken.com/u/security/api
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
